# Qualifier-aware catalog suggestions (schema / table / column)
statement ok
CREATE SCHEMA qual_ac;

statement ok
CREATE TABLE qual_ac.qt_tbl(col_s INTEGER, only_in_s INTEGER);

statement ok
CREATE TABLE qt_other(col_m INTEGER);

query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('SELECT * FROM qual_ac.qt', max_suggestion_count => 200) WHERE suggestion = 'qt_tbl' LIMIT 1;
----
qt_tbl	table

query I
SELECT COUNT(*) FROM sql_smart_auto_complete('SELECT * FROM qual_bad.qt', max_suggestion_count => 200) WHERE suggestion_type = 'table';
----
0

query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('SELECT qual_ac.qt_tbl.co', max_suggestion_count => 200) WHERE suggestion IN ('col_s', 'only_in_s', 'col_m') ORDER BY suggestion;
----
col_s	column
only_in_s	column

# Schema-qualified partial table: only tables in that schema (not main.*)
statement ok
CREATE SCHEMA filt_s;

statement ok
CREATE TABLE filt_s.t_scoped(a INTEGER);

statement ok
CREATE TABLE main.t_other(x INTEGER);

query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('SELECT * FROM filt_s.t', max_suggestion_count => 200) WHERE suggestion = 't_scoped' LIMIT 1;
----
t_scoped	table

query I
SELECT COUNT(*)::BIGINT FROM sql_smart_auto_complete('SELECT * FROM filt_s.t', max_suggestion_count => 200) WHERE suggestion = 't_other';
----
0

# Attached catalog: bad schema under catalog yields no table suggestions; good schema still completes
statement ok
ATTACH ':memory:' AS ac_cat;

statement ok
CREATE SCHEMA ac_cat.scoped_sch;

statement ok
CREATE TABLE ac_cat.scoped_sch.tab_in_s(c INTEGER);

query I
SELECT COUNT(*)::BIGINT FROM sql_smart_auto_complete('SELECT * FROM ac_cat.badschema.z', max_suggestion_count => 200) WHERE suggestion_type = 'table';
----
0

query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('SELECT * FROM ac_cat.scoped_sch.ta', max_suggestion_count => 200) WHERE suggestion = 'tab_in_s' LIMIT 1;
----
tab_in_s	table

# FromClause slice after leading WITH: same schema-qualified table completion
query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('WITH w AS (SELECT 1) SELECT * FROM qual_ac.qt', max_suggestion_count => 200) WHERE suggestion = 'qt_tbl' LIMIT 1;
----
qt_tbl	table

# Comma-separated FROM (subquery + schema-qualified table): second table ref still completes
query II
SELECT suggestion, suggestion_type FROM sql_smart_auto_complete('SELECT * FROM (SELECT 1) x, qual_ac.qt', max_suggestion_count => 200) WHERE suggestion = 'qt_tbl' LIMIT 1;
----
qt_tbl	table

# Grammar-backed FROM list (FromClause matcher): incomplete JOIN still completes (table / keyword), not column type at this cursor position
query I
SELECT COUNT(*)::BIGINT FROM sql_smart_auto_complete('SELECT c FROM qual_ac.qt_tbl x JOIN ', max_suggestion_count => 200) WHERE suggestion_type = 'column';
----
0

# multi statements
query II
SELECT suggestion, suggestion_start FROM sql_smart_auto_complete('SELECT 42; SEL') LIMIT 1;
----
SELECT 	11

