# name: test/sql/create_type.test
# description: Test sql_smart_auto_complete
# group: [sql]

require smart_autocomplete

query II
SELECT suggestion, suggestion_start FROM sql_smart_auto_complete('CREATE TY') LIMIT 1;
----
TYPE 	7

query II
SELECT suggestion, suggestion_start FROM sql_smart_auto_complete('CREATE TYPE my_type AS ENU') LIMIT 1;
----
ENUM	23

query II
SELECT suggestion, suggestion_start FROM sql_smart_auto_complete('CREATE TYPE my_type AS TIME WITH TI') LIMIT 1;
----
TIME 	33

query II
SELECT suggestion, suggestion_start FROM sql_smart_auto_complete('CREATE TYPE my_type AS ROW(ts TIMESTAMP WITH TIME ZON') LIMIT 1;
----
ZONE 	50
